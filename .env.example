# 複製此文件為 .env，填入你的 API Key
# ⚠️ 千萬不要把 .env 提交到 Git！

# ─── 新聞 API Keys ────────────────────────────────────────────────
# NewsData.io（免費 plan: 500 requests/day）
# 申請：https://newsdata.io/
VITE_NEWSDATA_API_KEY=pub_YOUR_KEY_HERE

# rss2json（免費 plan: 10,000 requests/month）
# 申請：https://rss2json.com/
VITE_RSS2JSON_API_KEY=YOUR_KEY_HERE

# ─── 部署 URL ─────────────────────────────────────────────────────
# 你的 Cloudflare Worker URL（部署後替換）
VITE_WORKER_BASE_URL=https://YOUR_WORKER_SUBDOMAIN.workers.dev

# ─── 分析 & 廣告（可選）───────────────────────────────────────────
VITE_GOOGLE_AD_CLIENT=ca-pub-YOUR_ADSENSE_ID
VITE_GA_TRACKING_ID=G-YOUR_GA4_ID

# ─── Supabase（用於 cache 讀寫）────────────────────────────────
# ⚠️ 這些是 PUBLIC read key，可安全暴露在前端（遵守 RLS 即可）
# anon key 從 Supabase Dashboard → Project Settings → API 取得
